// Reference schema for teams migrating to SQL later.
// This app intentionally does NOT use Prisma at runtime; it uses file-backed storage.

model User {
  id               String   @id
  email            String   @unique
  name             String
  passwordHash     String
  captureSubdomain String   @unique
  createdAt        DateTime
}

model CapturedWebhook {
  id         String   @id
  userId     String
  method     String
  path       String
  query      Json
  headers    Json
  bodyText   String
  bodyBase64 String?
  sourceHint String
  contentType String
  receivedAt DateTime
  ipAddress  String
}

model ReplayLog {
  id           String   @id
  webhookId    String
  userId       String
  targetUrl    String
  statusCode   Int
  responseBody String
  durationMs   Int
  createdAt    DateTime
}
